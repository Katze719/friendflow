# Postgres
POSTGRES_USER=friendflow
POSTGRES_PASSWORD=change_me_please
POSTGRES_DB=friendflow

# Backend
DATABASE_URL=postgres://friendflow:change_me_please@db:5432/friendflow
JWT_SECRET=please_generate_a_long_random_string_here_min_32_chars
JWT_EXPIRY_HOURS=1068
BIND_ADDR=0.0.0.0:3000
# Not strictly required when frontend and backend share an origin via the
# bundled nginx proxy (default docker-compose setup). Set it anyway as a
# defence-in-depth measure and for browser tooling during dev. Comma-separated.
# Example for production: https://friendtools.site,https://www.friendtools.site
CORS_ORIGIN=http://localhost:8080
# Public label exposed to login screens and the mobile instance picker.
INSTANCE_NAME=friendflow
RUST_LOG=info,tower_http=info,sqlx=warn

# How new sign-ups are handled:
#   approval (default) - new accounts are "pending" until an admin approves
#                        them. Safe for private instances.
#   open               - new accounts are auto-approved and can sign in
#                        immediately. Use for public / self-hosted demos.
REGISTRATION_MODE=approval

# --- Password recovery ---
# If SMTP_HOST is set, the login screen offers a "Forgot password?" link
# that emails a one-hour, single-use reset link. Leave SMTP_HOST empty to
# fully disable the feature (the link won't appear).
#
# APP_BASE_URL must be the public URL of your frontend - it's used to
# build the reset link in the outbound mail. Without it we fall back to
# the first entry from CORS_ORIGIN, which is fine for local docker setups
# but you should set it explicitly in production.
#APP_BASE_URL=https://friendflow.example
# Native app links for the official friendflow.site deployment. Android may
# need both the Google Play App Signing certificate and the separately
# distributed APK certificate, separated by commas. Leave empty for self-hosts.
#APP_LINK_IOS_TEAM_ID=ABCDE12345
#APP_LINK_ANDROID_SHA256_CERT_FINGERPRINTS=AA:BB:...:FF,11:22:...:00
# Optional mobile-app compatibility metadata returned by /api/app/version.
# Set APP_MIN_SUPPORTED_VERSION only when old installed apps must stop using this backend.
#APP_MIN_SUPPORTED_VERSION=1.0.0
# Optional override; when unset, /api/app/version uses the backend build's git version.
#APP_LATEST_VERSION=1.0.0
#APP_IOS_STORE_URL=https://apps.apple.com/us/app/friendflow-group-planner/id6786750453
#APP_ANDROID_STORE_URL=https://play.google.com/store/apps/details?id=app.friendflow.mobile
# Optional custom text for available/required update notices, for example while store review is pending.
#APP_UPDATE_MESSAGE=
#SMTP_HOST=smtp.example.com
#SMTP_PORT=587
# starttls (default), tls (implicit, usually port 465), or none (dev only)
#SMTP_ENCRYPTION=starttls
#SMTP_USERNAME=apikey
#SMTP_PASSWORD=your_smtp_password
# Either a bare address or a "Name <address>" mailbox.
#SMTP_FROM=friendflow <noreply@friendflow.example>

# Frontend
# Empty = same-origin (nginx proxies /api to the backend). Set only for non-docker dev.
VITE_API_URL=
# For Capacitor/mobile builds: friendflow server shown as the default login target.
#VITE_DEFAULT_INSTANCE_URL=https://app.friendflow.example
#VITE_DEFAULT_INSTANCE_LABEL=friendflow

# Controls what unauthenticated visitors see at "/".
#   login   (default) - redirect straight to the sign-in form.
#   landing           - public marketing page explaining what friendflow
#                       is, with sign-in / sign-up buttons in the top right.
# Useful when the instance is exposed to the open web.
LANDING_MODE=login

# --- Google Calendar sync (optional, Friendflow → Google one-way) ---
# Leave GOOGLE_CLIENT_ID unset to disable. Requires Google Cloud OAuth client (Web),
# OAuth consent screen, and Calendar API enabled.
#GOOGLE_CLIENT_ID=
#GOOGLE_CLIENT_SECRET=
# Exact redirect URI registered in Google Cloud · usually your public URL:
#GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8080/api/auth/google-calendar/callback
# Random 64 hex chars (openssl rand -hex 32). Used to encrypt refresh tokens in the database.
#GOOGLE_TOKEN_ENCRYPTION_KEY=
# IANA zone for all-day events → Google Calendar date fields (browser “local day” is stored as UTC).
# Default in app: Europe/Berlin. Set e.g. America/Los_Angeles for a US-only instance.
#APP_TIMEZONE=Europe/Berlin
